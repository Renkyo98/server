SUBDIR=char npc map item battle magic newbilu mylua
LIBS=char/libchar.a npc/libnpc.a map/libmap.a\
item/libitem.a \
magic/libmagic.a \
battle/libbattle.a \
newbilu/libnewbilu.a \
